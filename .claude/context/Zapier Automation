output[f'tool_{i}_use_case'] = tool.get('use_case', '')    # "Centralize all construction..."
output[f'tool_{i}_why'] = tool.get('why_it_fits', '')      # "At 1,000 people, Excel breaks..."
output[f'tool_{i}_notes'] = tool.get('notes', '')          # "Start with Notion's template..."
return output


